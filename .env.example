# Environment variables that are actually read by hCTF2
# Note: Most configuration is done via CLI flags, not env vars

# Security (works with --dev flag or set explicitly)
JWT_SECRET=change-this-to-a-random-secret-min-32-chars

# CORS configuration
# CORS_ORIGINS=https://app.example.com,https://admin.example.com

# SMTP for password reset emails
# SMTP_HOST=smtp.gmail.com
# SMTP_FROM=noreply@example.com
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password

# OpenTelemetry / Observability
# ENVIRONMENT=production
# OTEL_EXPORTER_STDOUT=true
# OTEL_METRICS_PROMETHEUS=true
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
